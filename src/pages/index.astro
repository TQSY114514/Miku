---
// TQSY's Space - Astro Component
const title = "TQSY's Space";
const mikuCover = "https://phototourl.com/i/2024/10/26/671cd6c0850df.jpg";
const mikuAudio = "https://videotourl.com/u/2024/10/26/671cd72225345.mp3";
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      /* 全局背景设置 */
      body {
        margin: 0;
        padding: 0;
        font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
        background: linear-gradient(135deg, #e0f7fa 0%, #80deea 100%);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #333;
      }

      /* 容器卡片 */
      .container {
        text-align: center;
        background: rgba(255, 255, 255, 0.7);
        padding: 2rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(10px);
        max-width: 500px;
        width: 90%;
      }

      h1 {
        margin-bottom: 1.5rem;
        color: #00acc1;
        font-size: 2rem;
      }

      /* 封面图样式 */
      .album-cover {
        width: 300px;
        height: 300px;
        object-fit: cover;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        margin-bottom: 1.5rem;
        transition: transform 0.3s ease;
      }

      .album-cover:hover {
        transform: scale(1.03);
      }

      /* 播放器容器 */
      .audio-player-wrapper {
        margin-top: 1rem;
        width: 100%;
      }

      audio {
        width: 100%;
        border-radius: 30px;
      }

      .footer-text {
        margin-top: 1.5rem;
        font-size: 0.9rem;
        color: #666;
      }

      /* --- 📱 手机端自动适配 (响应式代码) --- */
      @media (max-width: 768px) {
        .container {
          padding: 1.2rem; /* 缩小外边距 */
        }

        h1 {
          font-size: 1.4rem; /* 缩小标题 */
          margin-bottom: 1rem;
        }

        .album-cover {
          width: 180px; /* 显著缩小封面，给播放器腾位置 */
          height: 180px;
          margin-bottom: 1rem;
        }

        .audio-player-wrapper {
          transform: scale(0.9); /* 整体轻微缩小播放器 */
        }

        .footer-text {
          font-size: 0.8rem;
          margin-top: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>{title}</h1>
      
      <img src={mikuCover} class="album-cover" alt="Miku Album Cover" />
      
      <div class="audio-player-wrapper">
        <p style="margin-bottom: 8px; font-weight: bold;">正在播放：橙交差点</p>
        <audio controls>
          <source src={mikuAudio} type="audio/mpeg" />
          您的浏览器不支持音频播放。
        </audio>
      </div>

      <p class="footer-text">Welcome to TQSY's hidden space. 114514 version. awa</p>
    </div>
  </body>
</html>
