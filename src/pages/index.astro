    <a href="mailto:tqishengyan@gmail.com" class="email-chip">tqishengyan@gmail.com</a>
    <a href="mailto:3635316905@qq.com" class="email-chip">3635316905@qq.com</a>
    <a href="mailto:tianqishengyan_zhj@163.com" class="email-chip">tianqishengyan_zhj@163.com</a>
    <a href="mailto:tianqishengyan_zhj@outlook.com" class="email-chip">tianqishengyan_zhj@outlook.com</a>
  </div>

  <script is:inline>
    console.log(
      "%c ✨ TQSY's Space %c 100% Handcrafted | Weather Holy Salt ", 
      "color: white; background: #1d1d1f; padding: 6px 10px; border-radius: 4px 0 0 4px; font-weight: bold;", 
      "color: white; background: #00cfb5; padding: 6px 10px; border-radius: 0 4px 4px 0; font-weight: bold;"
    );

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    
    let idleTimer;
    const resetIdleTimer = () => {
      document.body.classList.remove('is-idle');
      clearTimeout(idleTimer);
      if (!prefersReducedMotion) {
        idleTimer = setTimeout(() => { document.body.classList.add('is-idle'); }, 5000); 
      }
    };
    ['mousemove', 'mousedown', 'keydown', 'touchstart', 'scroll'].forEach(evt => 
      window.addEventListener(evt, resetIdleTimer, { passive: true })
    );
    resetIdleTimer();

    // ✨ 修复：连同新增加的分类标题一起纳入排队动画队列
    const items = document.querySelectorAll('.nav-item, .category-title');
    const itemsArray = Array.from(items); 
    let staggerDelay = 0;
    let resetTimer = null;

    const observer = new IntersectionObserver((entries) => {
      const visibleEntries = entries.filter(entry => 
        entry.isIntersecting || entry.boundingClientRect.top < window.innerHeight
      );
      if (visibleEntries.length === 0) return;

      visibleEntries.sort((a, b) => itemsArray.indexOf(a.target) - itemsArray.indexOf(b.target));

      visibleEntries.forEach((entry) => {
        if (!entry.target.classList.contains('show')) {
          if (prefersReducedMotion) {
            entry.target.classList.add('show');
          } else {
            setTimeout(() => { entry.target.classList.add('show'); }, staggerDelay);
            staggerDelay += 80; 
          }
          observer.unobserve(entry.target);
        }
      });

      if (!prefersReducedMotion) {
        clearTimeout(resetTimer);
        resetTimer = setTimeout(() => { staggerDelay = 0; }, 300);
      }
    }, { threshold: 0, rootMargin: "0px 0px -50px 0px" });
    items.forEach(item => observer.observe(item));

    const audio = document.getElementById('mainAudio');
    const playBtn = document.getElementById('playBtn');
    const playerCard = document.getElementById('playerCard');

    playBtn.onclick = (e) => {
      e.stopPropagation();
      if (audio.paused) {
        audio.play().then(() => { playerCard.classList.add('is-playing'); });
      } else {
        audio.pause();
        playerCard.classList.remove('is-playing');
      }
    };

    const emailChips = document.querySelectorAll('.email-chip');
    
    const updateScrollProgress = () => {
      const maxScroll = document.body.offsetHeight - window.innerHeight;
      
      if (maxScroll <= 0) {
        emailChips.forEach(chip => {
          chip.style.setProperty('--chip-x', '0px');
          chip.style.setProperty('--chip-op', '1');
        });
        document.body.classList.add('is-bottom');
        return;
      }

      const triggerZone = 250;
      const startScroll = maxScroll - triggerZone;
      const currentScroll = window.scrollY;

      let progress = 0;
      if (currentScroll >= startScroll) {
        progress = (currentScroll - startScroll) / triggerZone;
      }
      progress = Math.max(0, Math.min(1, progress));

      document.body.classList.toggle('is-bottom', progress > 0);

      emailChips.forEach((chip, index) => {
        if (prefersReducedMotion) {
          chip.style.setProperty('--chip-x', '0px');
          chip.style.setProperty('--chip-op', '1');
          return;
        }

        const stagger = 0.15;
        const delay = index * stagger;
        
        let chipProgress = Math.max(0, progress - delay) / (1 - stagger * 3);
        chipProgress = Math.max(0, Math.min(1, chipProgress));

        const easeOut = 1 - Math.pow(1 - chipProgress, 2);

        chip.style.setProperty('--chip-x', `${40 * (1 - easeOut)}px`);
        chip.style.setProperty('--chip-op', easeOut);
      });
    };

    window.addEventListener('scroll', updateScrollProgress, { passive: true });
    window.addEventListener('resize', updateScrollProgress, { passive: true });
    updateScrollProgress(); 

  </script>
</body>
</html>
