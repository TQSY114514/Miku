  <div class="player-card" id="playerCard">
    <img src="https://cdn.phototourl.com/free/2026-04-11-eee19110-0750-4557-be87-830a17b948b5.jpg" class="album-cover" alt="Miku Cover" width="50" height="50" decoding="async">
    <div class="song-info">
      <div class="song-name">橙交差点</div>
      <div class="song-artist">初音ミク</div>
    </div>
    <button class="play-pause" id="playBtn" aria-label="播放或暂停背景音乐">
      <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
    <audio id="mainAudio" loop preload="metadata">
      <source src="https://videotourl.com/audio/1775904309738-ed28bd2b-7261-4bb9-8cab-1ed6c1b5b0c9.mp3" type="audio/mpeg">
