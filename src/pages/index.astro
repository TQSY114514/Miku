---
// TQSY's Space - Cyber Digital Identity 版 (分区重构 + 性能瘦身)
const title = "TQSY's Space";
const description = "Welcome to Weather Holy Salt · TQSY's personal space 🪐";
const globalIcon = "https://cdn.phototourl.com/free/2026-05-22-13e55726-5b80-4cfa-843a-e8ba865c9b46.webp";
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{title}</title>
  
  <link rel="preconnect" href="https://cdn.phototourl.com" crossorigin />
  <link rel="preconnect" href="https://videotourl.com" crossorigin />

  <meta name="theme-color" content="#fcfcfc" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0a0a0c" media="(prefers-color-scheme: dark)" />
  <link rel="icon" href={globalIcon} />
  <link rel="apple-touch-icon" href={globalIcon} />

  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={globalIcon} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <style>
    :root {
      --miku-green: #00cfb5;
      --bg-white: #fcfcfc;
      --text-dark: #1d1d1f;
      --text-gray: #86868b;
      --glass: rgba(255, 255, 255, 0.85);
      --glass-border: rgba(0, 0, 0, 0.05);
      --glass-hover: rgba(0, 207, 181, 0.05);
      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg-white: #0a0a0c;
        --text-dark: #f5f5f7;
        --text-gray: #a1a1a6;
        --glass: rgba(30, 30, 32, 0.7);
        --glass-border: rgba(255, 255, 255, 0.08);
        --glass-hover: rgba(0, 207, 181, 0.15);
      }
    }

    ::selection { background-color: var(--miku-green); color: #ffffff; }

    * { 
      margin: 0; padding: 0; box-sizing: border-box; 
      -webkit-font-smoothing: antialiased; 
      -webkit-tap-highlight-color: transparent; 
    }
    ::-webkit-scrollbar { width: 0px; height: 0px; }

    body { 
      background-color: var(--bg-white); color: var(--text-dark); 
      font-family: -apple-system, BlinkMacSystemFont, system-ui, "Segoe UI", Roboto, "SF Pro Text", sans-serif; 
      overflow-x: hidden;
      /* ⚡ 修复首屏白闪：移除 body opacity 动画 */
      transition: background-color 0.5s var(--ease), color 0.5s var(--ease);
    }

    .bg-glow { 
      position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
      background: radial-gradient(circle at 80% 20%, rgba(0, 207, 181, 0.1) 0%, transparent 40%); 
      z-index: -1; pointer-events: none;
      transition: transform 3s var(--ease), opacity 3s var(--ease);
      /* ⚡ 性能优化：移除不必要的 will-change */
    }

    @keyframes ambientBreathe {
      0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.6; }
      50% { transform: scale(1.1) translate(-2%, 2%); opacity: 1; }
    }
    body.is-idle .bg-glow { animation: ambientBreathe 8s infinite ease-in-out; }

    .nav-list { transition: opacity 1.5s ease-in-out, filter 1.5s ease-in-out; }
    body.is-idle .nav-list { opacity: 0.35; filter: blur(1.5px); }
    body.is-idle .nav-list:hover { opacity: 1; filter: blur(0); }

    .hero { 
      height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; 
      animation: heroUp 1.2s var(--ease) 0.2s both;
      user-select: none; -webkit-user-select: none;
    }
    .hero h1 { 
      font-size: clamp(3rem, 10vw, 6rem); font-weight: 800; 
      background: linear-gradient(var(--text-dark), var(--text-gray)); 
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; 
      filter: blur(10px); text-shadow: 0 0 30px rgba(0,0,0,0.02);
      animation: unblur 1.2s var(--ease) 0.3s both;
    }
    .hero-sub { 
      color: var(--text-gray); letter-spacing: 0.3em; text-transform: uppercase; 
      font-size: 0.8rem; margin-top: 10px; opacity: 0; animation: fadeIn 1s var(--ease) 0.8s forwards;
    }

    .container { max-width: 500px; margin: 0 auto; padding: 0 20px 250px 20px; }
    
    /* ✨ 新增：分类标题样式，构建信息层级 */
    .category-title {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin: 40px 0 16px 12px;
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.8s var(--ease), transform 0.8s var(--ease);
    }
    .category-title.show { opacity: 0.8; transform: translateY(0); }

    .nav-item { 
      display: flex; align-items: center; justify-content: space-between; 
      /* ⚡ GPU减负：统一降级到 blur(12px) */
      padding: 22px 28px; background: var(--glass); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border); border-radius: 24px; text-decoration: none; 
      color: var(--text-dark); font-weight: 600; margin-bottom: 16px; 
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s var(--ease), transform 0.8s var(--ease), border-color 0.4s var(--ease), box-shadow 0.4s var(--ease), background-color 0.5s var(--ease);
      /* ⚡ 性能优化：仅保留高频动画元素的 will-change */
      will-change: transform, opacity;
      user-select: none; -webkit-user-select: none;
    }
    .nav-item span { transition: color 0.4s var(--ease); }
    .nav-item.show { opacity: 1; transform: translateY(0); }
    .nav-item.show:hover { 
      transform: translateY(-4px); border-color: var(--miku-green); box-shadow: 0 10px 30px rgba(0,207,181,0.1);
    }
    .nav-item.show:hover span { color: var(--miku-green); }
    .nav-item.show:active { transform: scale(0.97); background: var(--glass-hover); }

    .source-footer {
      text-align: center; margin-top: 60px; opacity: 0; animation: fadeIn 1.5s var(--ease) 1s forwards;
    }
    .source-footer a {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      font-size: 11px; color: var(--text-gray); text-decoration: none; letter-spacing: 0.05em;
      transition: color 0.3s var(--ease), opacity 0.3s var(--ease);
      user-select: none; -webkit-user-select: none; opacity: 0.6;
    }
    .source-footer a:hover { color: var(--miku-green); opacity: 1; }

    .player-card { 
      position: fixed; left: 25px; bottom: 25px; width: 300px; padding: 12px; 
      /* ⚡ GPU减负：降级到 blur(12px) */
      background: var(--glass); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-radius: 20px; border: 1px solid rgba(0,207,181,0.2); 
      display: flex; align-items: center; gap: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); 
      z-index: 1000; opacity: 0; animation: slideInLeft 1.2s var(--ease) 1s forwards;
      transition: background-color 0.5s var(--ease); 
      will-change: transform, opacity;
      user-select: none; -webkit-user-select: none;
    }
    .album-cover { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; transition: 0.4s var(--ease); pointer-events: none; }
    .is-playing .album-cover { box-shadow: 0 0 20px rgba(0,207,181,0.3); transform: scale(1.05); }

    .song-info { flex: 1; overflow: hidden; }
    .song-name { font-size: 13px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-artist { font-size: 11px; color: var(--miku-green); }
    
    .play-pause { 
      width: 34px; height: 34px; background: var(--text-dark); color: var(--bg-white); 
      border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: 0.3s;
    }
    .play-pause:active { transform: scale(0.85); }
    
    .play-pause svg { width: 14px; height: 14px; fill: currentColor; }
    #icon-pause { display: none; }
    .is-playing #icon-play { display: none; }
    .is-playing #icon-pause { display: block; }

    .contact-panel { 
      position: fixed; right: 25px; bottom: 25px; display: flex; flex-direction: column; 
      align-items: flex-end; gap: 8px; z-index: 1001; pointer-events: none; 
    }
    body.is-bottom .contact-panel { pointer-events: auto; }

    .email-chip { 
      --chip-x: 40px;
      --chip-op: 0;
      /* ⚡ GPU减负：降级到 blur(12px) */
      background: var(--glass); padding: 8px 16px; border-radius: 50px; font-size: 10px; 
      color: var(--text-gray); border: 1px solid var(--glass-border); text-decoration: none; font-family: monospace; 
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      
      transform: translateX(var(--chip-x)); opacity: var(--chip-op);
      transition: background 0.3s, color 0.3s, border 0.3s;
      user-select: none; -webkit-user-select: none;
    }
    .email-chip:hover { 
      background: var(--miku-green); color: white; border-color: var(--miku-green); 
      transform: translateX(calc(var(--chip-x) - 5px)); 
    }

    @media (max-width: 600px) {
      .player-card { width: 175px !important; left: 10px !important; bottom: 10px !important; padding: 8px !important; gap: 8px !important; }
      .album-cover { width: 35px !important; height: 35px !important; }
      .song-name { font-size: 10.5px !important; }
      .play-pause { width: 28px !important; height: 28px !important; }
      .contact-panel { right: 10px !important; bottom: 10px !important; gap: 4px !important; }
      .email-chip { padding: 5px 10px !important; font-size: 8.5px !important; }
      .hero h1 { font-size: 3.2rem !important; }
    }

    @keyframes heroUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @keyframes unblur { to { filter: blur(0); } }
    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes slideInLeft { from { opacity: 0; transform: translateX(-30px); } to { opacity: 1; transform: translateX(0); } }

    @media (prefers-reduced-motion: reduce) {
      *, ::before, ::after {
        animation-duration: 0.01ms !important; animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important; scroll-behavior: auto !important;
      }
      .nav-item, .category-title { opacity: 1; transform: translateY(0); }
      .email-chip { opacity: 1; transform: translateX(0) !important; }
      body.is-idle .bg-glow { animation: none !important; } 
    }
  </style>
</head>
<body>

  <div class="bg-glow"></div>

  <section class="hero">
    <h1>{title}</h1>
    <p class="hero-sub">Weather Holy Salt · TQSY</p>
  </section>

  <div class="container">
    <div class="nav-list" id="navList">
      
      <div class="category-title">💻 Code & Dev</div>
