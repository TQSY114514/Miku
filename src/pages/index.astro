---
// TQSY's Space - 最终修复版
const title = "TQSY's Space";
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    :root {
      --miku-green: #00cfb5;
      --bg-white: #fcfcfc;
      --text-dark: #1d1d1f;
      --text-gray: #86868b;
      --glass: rgba(255, 255, 255, 0.85);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
    body { background-color: var(--bg-white); color: var(--text-dark); font-family: -apple-system, sans-serif; overflow-x: hidden; }
    
    /* 背景流光 */
    .bg-glow { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: radial-gradient(circle at 80% 20%, rgba(0, 207, 181, 0.05) 0%, transparent 40%); z-index: -1; }

    /* 标题 */
    .hero { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
    .hero h1 { font-size: clamp(3rem, 10vw, 6rem); font-weight: 800; background: linear-gradient(#1d1d1f, #86868b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* 链接 */
    .container { max-width: 500px; margin: 0 auto; padding-bottom: 200px; }
    .nav-item { display: flex; align-items: center; justify-content: space-between; padding: 20px 25px; background: var(--glass); backdrop-filter: blur(20px); border: 1px solid rgba(0,0,0,0.05); border-radius: 20px; text-decoration: none; color: var(--text-dark); font-weight: 600; margin-bottom: 12px; transition: 0.3s; }
    .nav-item:hover { transform: translateY(-3px); border-color: var(--miku-green); color: var(--miku-green); }

    /* 播放器 */
    .player-card { position: fixed; left: 25px; bottom: 25px; width: 280px; padding: 12px; background: var(--glass); backdrop-filter: blur(25px); border-radius: 20px; border: 1px solid rgba(0,0,0,0.08); display: flex; align-items: center; gap: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); z-index: 1000; transition: 0.5s; }
    .album-cover { width: 45px; height: 45px; border-radius: 10px; object-fit: cover; background: #eee; }
    .is-playing .album-cover { animation: rotate 10s linear infinite; }
    .song-info { flex: 1; overflow: hidden; }
    .song-name { font-size: 14px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-artist { font-size: 11px; color: var(--text-gray); }
    .play-pause { width: 35px; height: 35px; background: var(--text-dark); color: white; border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }

    @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="bg-glow"></div>
  <section class="hero"><h1>{title}</h1></section>

  <div class="container">
    <div class="nav-list">
      <a href="https://github.com/TQSY114514" class="nav-item">GitHub</a>
      <a href="https://luogu.com.cn/user/1849345" class="nav-item">Luogu</a>
      <a href="https://space.bilibili.com/1180124107" class="nav-item">Bilibili</a>
    </div>
  </div>

  <div class="player-card" id="playerCard">
    <img src="https://img.moegirl.org.cn/common/thumb/b/b7/Miku_v3_visual.png/250px-Miku_v3_visual.png" class="album-cover" id="cover">
    <div class="song-info">
      <div class="song-name" id="statusText">橙交差点</div>
      <div class="song-artist">初音ミク</div>
    </div>
    <button class="play-pause" id="playBtn">▶</button>
    <audio id="mainAudio" loop>
      <source src="/miku.mp3" type="audio/mpeg">
      <source src="./miku.mp3" type="audio/mpeg">
    </audio>
  </div>

  <script is:inline>
    const audio = document.getElementById('mainAudio');
    const playBtn = document.getElementById('playBtn');
    const playerCard = document.getElementById('playerCard');
    const statusText = document.getElementById('statusText');

    playBtn.onclick = async () => {
      if (audio.paused) {
        statusText.innerText = "加载中...";
        try {
          // 强制重新探测资源位置
          await audio.load();
          await audio.play();
          playBtn.innerText = "⏸";
          playerCard.classList.add('is-playing');
          statusText.innerText = "橙交差点";
        } catch (err) {
          console.error(err);
          // 如果还是404，给用户一个明确的Debug提示
          alert("文件还是 404！请去 Vercel 选 Redeploy 并勾选 Clean Cache。");
          statusText.innerText = "文件丢失(404)";
        }
      } else {
        audio.pause();
        playBtn.innerText = "▶";
        playerCard.classList.remove('is-playing');
      }
    };
  </script>
</body>
</html>
