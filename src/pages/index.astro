---
// miku114514.vercel.app - 个人导航页
const title = "Miku's Space";
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    /* 1. 全局样式 - 纯净白色主题 */
    :root {
      --bg-color: #fcfcfc;
      --text-main: #1d1d1f;
      --text-sub: #86868b;
      --card-bg: #ffffff;
      --card-shadow: rgba(0, 0, 0, 0.04);
      --accent: #0071e3; /* 经典蓝色，你也可以改成初音绿 #00cfb5 */
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body { 
      background-color: var(--bg-color);
      color: var(--text-main);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.5;
      overflow-x: hidden;
    }

    /* 2. 第一屏：震撼大标题 */
    .hero {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 0 20px;
    }

    .hero h1 {
      font-size: clamp(3rem, 10vw, 6rem); /* 响应式字体大小 */
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
      color: var(--text-main);
    }

    .hero p {
      font-size: 1.2rem;
      color: var(--text-sub);
      font-weight: 400;
    }

    .scroll-down {
      position: absolute;
      bottom: 40px;
      font-size: 14px;
      color: var(--text-sub);
      animation: bounce 2s infinite;
    }

    /* 3. 第二屏：按钮列表 */
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 100px 20px;
    }

    .section-title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-sub);
      margin-bottom: 30px;
      text-align: center;
    }

    .nav-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 22px;
      background: var(--card-bg);
      border: 1px solid #efefef;
      border-radius: 18px;
      text-decoration: none;
      color: var(--text-main);
      font-weight: 500;
      font-size: 17px;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 6px var(--card-shadow);
    }

    .nav-item:hover {
      transform: scale(1.02);
      box-shadow: 0 10px 20px rgba(0,0,0,0.08);
      border-color: var(--accent);
      color: var(--accent);
    }

    /* 平台微调 - 悬浮时的品牌色（可选） */
    .bilibili:hover { color: #fb7299; border-color: #fb7299; }
    .luogu:hover { color: #3498db; border-color: #3498db; }
    .github:hover { color: #24292e; border-color: #24292e; }

    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
      40% {transform: translateY(-8px);}
      60% {transform: translateY(-4px);}
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 3.5rem; }
    }
  </style>
</head>
<body>

  <section class="hero">
    <h1>{title}</h1>
    <p>Code, Algorithm & Life.</p>
    <div class="scroll-down">滚动探索 ↓</div>
  </section>

  <div class="container">
    <p class="section-title">Social Connect</p>
    
    <div class="nav-list">
      <a href="https://github.com/TQSY114514" class="nav-item github" target="_blank">GitHub</a>
      
      <a href="https://luogu.com.cn/user/1849345" class="nav-item luogu" target="_blank">Luogu</a>
      
      <a href="https://space.bilibili.com/1180124107" class="nav-item bilibili" target="_blank">Bilibili</a>
      
      <a href="https://x.com/TianY43737" class="nav-item" target="_blank">X (Twitter)</a>
      
      <a href="https://www.instagram.com/tqsy114514/" class="nav-item" target="_blank">Instagram</a>
      
      <a href="https://www.facebook.com/profile.php?id=61577768467133" class="nav-item" target="_blank">Facebook</a>
    </div>

    <footer style="margin-top: 80px; text-align: center; color: #bbb; font-size: 12px;">
      © 2026 {title}. Built with Astro & Vercel.
    </footer>
  </div>

</body>
</html>
