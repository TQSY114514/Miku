---
// TQSY's Space - 完整兼容版
const title = "TQSY's Space";
const mikuCover = "https://phototourl.com/i/2024/10/26/671cd6c0850df.jpg";
const mikuAudio = "https://videotourl.com/u/2024/10/26/671cd72225345.mp3";
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <style>
      /* 基础重置，防止边距撑开页面 */
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: 'PingFang SC', sans-serif;
        background: linear-gradient(135deg, #e0f7fa 0%, #80deea 100%);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow-x: hidden; /* 防止左右晃动 */
      }

      /* 电脑端主卡片 */
      .main-card {
        text-align: center;
        background: rgba(255, 255, 255, 0.75);
        padding: 40px;
        border-radius: 30px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(12px);
        width: 450px; /* 电脑端固定宽度 */
        border: 1px solid rgba(255, 255, 255, 0.3);
      }

      h1 {
        color: #00acc1;
        font-size: 2.2rem;
        margin-top: 0;
        margin-bottom: 20px;
      }

      .album-cover {
        width: 320px;
        height: 320px;
        object-fit: cover;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        margin-bottom: 25px;
      }

      .audio-wrapper {
        width: 100%;
      }

      audio {
        width: 100%;
        height: 45px;
      }

      .footer {
        margin-top: 25px;
        color: #666;
        font-size: 14px;
        opacity: 0.8;
      }

      /* --- 📱 手机端适配 (关键补丁) --- */
      @media (max-width: 768px) {
        .main-card {
          width: 85% !important; /* 强制卡片宽度 */
          padding: 20px !important; /* 缩小内边距 */
          border-radius: 20px !important;
        }

        h1 {
          font-size: 1.5rem !important; /* 缩小标题 */
          margin-bottom: 15px !important;
        }

        .album-cover {
          width: 160px !important; /* 封面图强制缩小一半以上 */
          height: 160px !important;
          margin-bottom: 15px !important;
        }

        audio {
          height: 36px !important; /* 压扁播放器 */
        }

        .footer {
          font-size: 12px !important;
          margin-top: 15px !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="main-card">
      <h1>{title}</h1>
      
      <img src={mikuCover} class="album-cover" alt="Miku" />
      
      <div class="audio-wrapper">
        <p style="margin-bottom: 10px; font-size: 0.9rem; color: #555;">正在播放：橙交差点</p>
        <audio controls>
          <source src={mikuAudio} type="audio/mpeg" />
          您的浏览器太旧啦
        </audio>
      </div>

      <div class="footer">
        TQSY · 2024 · 114514 Version
      </div>
    </div>
  </body>
</html>
