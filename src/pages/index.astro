---
// TQSY's Space - 极致纯净终极完全体
const title = "TQSY's Space";
const description = "Welcome to Weather Holy Salt · TQSY's personal space 🪐";
// 全局统一图标与头像直链
const globalIcon = "https://cdn.phototourl.com/free/2026-05-22-13e55726-5b80-4cfa-843a-e8ba865c9b46.webp";
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{title}</title>
  
  <meta name="theme-color" content="#fcfcfc" />
  
  <link rel="icon" href={globalIcon} />
  
  <link rel="apple-touch-icon" href={globalIcon} />

  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={globalIcon} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <style>
    :root {
      --miku-green: #00cfb5;
      --bg-white: #fcfcfc;
      --text-dark: #1d1d1f;
      --text-gray: #86868b;
      --glass: rgba(255, 255, 255, 0.85);
      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* 基础重置 */
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
    
    /* 隐藏滚动条 */
    ::-webkit-scrollbar { width: 0px; height: 0px; }

    body { 
      background-color: var(--bg-white); 
      color: var(--text-dark); 
      font-family: -apple-system, BlinkMacSystemFont, system-ui, "Segoe UI", Roboto, "SF Pro Text", sans-serif; 
      overflow-x: hidden;
      opacity: 0;
      animation: fadeInBody 1.5s var(--ease) forwards;
    }

    .bg-glow { 
      position: fixed; 
      top: 0; left: 0; 
      width: 100vw; height: 100vh; 
      background: radial-gradient(circle at 80% 20%, rgba(0, 207, 181, 0.06) 0%, transparent 40%); 
      z-index: -1; 
    }

    /* Hero 部分 */
    .hero { 
      height: 100vh; 
      display: flex; 
      flex-direction: column; 
      justify-content: center; 
      align-items: center; 
      animation: heroUp 1.2s var(--ease) 0.2s both;
    }
    
    /* ✨ 新增优化：给大头像加上精致的苹果风暗阴影与完美的圆形裁剪 */
    .hero-avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(0, 0, 0, 0.03);
      margin-bottom: 15px;
    }

    .hero h1 { 
      font-size: clamp(3rem, 10vw, 6rem); 
      font-weight: 800; 
      background: linear-gradient(#1d1d1f, #86868b); 
      -webkit-background-clip: text; 
      -webkit-text-fill-color: transparent; 
      filter: blur(10px);
      text-shadow: 0 0 30px rgba(0,0,0,0.02);
      animation: unblur 1.2s var(--ease) 0.3s both;
    }
    .hero-sub { 
      color: var(--text-gray); 
      letter-spacing: 0.3em; 
      text-transform: uppercase; 
      font-size: 0.8rem; 
      margin-top: 10px; 
      opacity: 0;
      animation: fadeIn 1s var(--ease) 0.8s forwards;
    }

    /* 导航列表 - 极致纯净态 */
    .container { max-width: 500px; margin: 0 auto; padding: 0 20px 250px 20px; }
    .nav-item { 
      display: flex; 
      align-items: center; 
      justify-content: space-between; 
      padding: 22px 28px; 
      background: var(--glass); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(0,0,0,0.05); 
      border-radius: 24px; 
      text-decoration: none; 
      color: var(--text-dark); 
      font-weight: 600; 
      margin-bottom: 16px; 
      transition: all 0.4s var(--ease);
      opacity: 0;
      transform: translateY(20px);
    }
    .nav-item span {
      transition: color 0.4s var(--ease);
    }
    .nav-item:hover { 
      transform: translateY(-4px); 
      border-color: var(--miku-green);
      box-shadow: 0 10px 30px rgba(0,207,181,0.1);
    }
    .nav-item:hover span {
      color: var(--miku-green);
    }
    .nav-item:active {
      transform: scale(0.97);
      background: rgba(0, 207, 181, 0.05);
    }

    /* 播放器卡片 */
    .player-card { 
      position: fixed; 
      left: 25px; bottom: 25px; 
      width: 300px; padding: 12px; 
      background: var(--glass); 
      backdrop-filter: blur(25px); 
      border-radius: 20px; 
      border: 1px solid rgba(0,207,181,0.2); 
      display: flex; 
      align-items: center; 
      gap: 12px; 
      box-shadow: 0 10px 40px rgba(0,0,0,0.1); 
      z-index: 1000; 
      opacity: 0;
      animation: slideInLeft 1.2s var(--ease) 1s forwards;
    }
    .album-cover { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; transition: 0.4s var(--ease); }
    .is-playing .album-cover { box-shadow: 0 0 20px rgba(0,207,181,0.3); transform: scale(1.05); }

    .song-info { flex: 1; overflow: hidden; }
    .song-name { font-size: 13px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-artist { font-size: 11px; color: var(--miku-green); }
    .play-pause { 
      width: 34px; height: 34px; 
      background: var(--text-dark); 
      color: white; border: none; 
      border-radius: 50%; cursor: pointer; 
      display: flex; align-items: center; justify-content: center;
      transition: 0.3s;
    }
    .play-pause:active { transform: scale(0.85); }

    /* 联系面板 */
    .contact-panel { 
      position: fixed; right: 25px; bottom: 25px; 
      display: flex; flex-direction: column; 
      align-items: flex-end; gap: 8px; 
      opacity: 0; transform: translateY(20px); 
      transition: 0.6s var(--ease); pointer-events: none; z-index: 1001; 
    }
    body.is-bottom .contact-panel { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .email-chip { 
      background: white; padding: 8px 16px; 
      border-radius: 50px; font-size: 10px; 
      color: var(--text-gray); border: 1px solid #eee; 
      text-decoration: none; transition: 0.3s; font-family: monospace; 
    }
    .email-chip:hover { background: var(--miku-green); color: white; transform: translateX(-5px); }

    /* 📱 移动端适配 */
    @media (max-width: 600px) {
      .player-card { 
        width: 175px !important; 
        left: 10px !important; 
        bottom: 10px !important; 
        padding: 8px !important;
        gap: 8px !important;
      }
      .album-cover { width: 35px !important; height: 35px !important; }
      .song-name { font-size: 10.5px !important; }
      .play-pause { width: 28px !important; height: 28px !important; font-size: 10px !important; }
      .contact-panel { 
        right: 10px !important; 
        bottom: 10px !important; 
        gap: 4px !important;
      }
      .email-chip { padding: 5px 10px !important; font-size: 8.5px !important; }
      .hero h1 { font-size: 3.2rem !important; }
    }

    /* 动画 */
    @keyframes fadeInBody { to { opacity: 1; } }
    @keyframes heroUp { from { transform: translateY(30px); } to { transform: translateY(0); } }
    @keyframes unblur { to { filter: blur(0); } }
    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes slideInLeft { from { opacity: 0; transform: translateX(-30px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes navStagger { to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>

  <div class="bg-glow"></div>

  <section class="hero">
    <img src={globalIcon} class="hero-avatar" alt="Avatar">
    <h1>{title}</h1>
    <p class="hero-sub">Weather Holy Salt · TQSY</p>
  </section>

  <div class="container">
    <div class="nav-list" id="navList">
      <a href="https://github.com/TQSY114514" target="_blank" rel="noopener noreferrer" class="nav-item"><span>GitHub</span> <span>→</span></a>
      <a href="https://bangumi.tv/user/tqsy114514" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Bangumi</span> <span>→</span></a>
      <a href="https://shequ.codemao.cn/user/1574587147" target="_blank" rel="noopener noreferrer" class="nav-item"><span>编程猫 (Codemao)</span> <span>→</span></a>
      <a href="https://luogu.com.cn/user/1849345" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Luogu</span> <span>→</span></a>
      <a href="https://space.bilibili.com/1180124107" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Bilibili</span> <span>→</span></a>
      <a href="https://x.com/TianY43737" target="_blank" rel="noopener noreferrer" class="nav-item"><span>X (Twitter)</span> <span>→</span></a>
      <a href="https://www.instagram.com/tqsy114514/" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Instagram</span> <span>→</span></a>
      <a href="https://www.facebook.com/profile.php?id=61577768467133" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Facebook</span> <span>→</span></a>
      <a href="https://www.touchgal.ink/user/383045/comment" target="_blank" rel="noopener noreferrer" class="nav-item"><span>TouchGal</span> <span>→</span></a>
      <a href="https://www.ioicode.com/user/54562" target="_blank" rel="noopener noreferrer" class="nav-item"><span>IOI Code</span> <span>→</span></a>
      <a href="https://www.nuomill.com/user/2649" target="_blank" rel="noopener noreferrer" class="nav-item"><span>Nuomill</span> <span>→</span></a>
    </div>
  </div>

  <div class="player-card" id="playerCard">
    <img src="https://cdn.phototourl.com/free/2026-04-11-eee19110-0750-4557-be87-830a17b948b5.jpg" class="album-cover" alt="Miku Cover">
    <div class="song-info">
      <div class="song-name">橙交差点</div>
      <div class="song-artist">初音ミク</div>
    </div>
    <button class="play-pause" id="playBtn">▶</button>
    <audio id="mainAudio" loop preload="metadata">
      <source src="https://videotourl.com/audio/1775904309738-ed28bd2b-7261-4bb9-8cab-1ed6c1b5b0c9.mp3" type="audio/mpeg">
    </audio>
  </div>

  <div class="contact-panel">
    <a href="mailto:tqishengyan@gmail.com" class="email-chip">tqishengyan@gmail.com</a>
    <a href="mailto:3635316905@qq.com" class="email-chip">3635316905@qq.com</a>
    <a href="mailto:tianqishengyan_zhj@163.com" class="email-chip">tianqishengyan_zhj@163.com</a>
    <a href="mailto:tianqishengyan_zhj@outlook.com" class="email-chip">tianqishengyan_zhj@outlook.com</a>
  </div>

  <script is:inline>
    const items = document.querySelectorAll('.nav-item');
    items.forEach((item, index) => {
      item.style.animation = `navStagger 1.2s cubic-bezier(0.16, 1, 0.3, 1) ${0.5 + index * 0.1}s forwards`;
    });

    const audio = document.getElementById('mainAudio');
    const playBtn = document.getElementById('playBtn');
    const playerCard = document.getElementById('playerCard');

    playBtn.onclick = (e) => {
      e.stopPropagation();
      if (audio.paused) {
        audio.play().then(() => {
          playBtn.innerText = "⏸";
          playerCard.classList.add('is-playing');
        });
      } else {
        audio.pause();
        playBtn.innerText = "▶";
        playerCard.classList.remove('is-playing');
      }
    };

    window.onscroll = () => {
      const isBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 120;
      document.body.classList.toggle('is-bottom', isBottom);
    };
  </script>
</body>
</html>
