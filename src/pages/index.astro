---
// TQSY's Space - 成功复刻版
const title = "TQSY's Space";
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    :root {
      --miku-green: #00cfb5;
      --bg-white: #fcfcfc;
      --text-dark: #1d1d1f;
      --text-gray: #86868b;
      --glass: rgba(255, 255, 255, 0.85);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
    body { background-color: var(--bg-white); color: var(--text-dark); font-family: -apple-system, system-ui, sans-serif; overflow-x: hidden; }
    
    .bg-glow { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: radial-gradient(circle at 80% 20%, rgba(0, 207, 181, 0.05) 0%, transparent 40%); z-index: -1; }

    /* 标题区 */
    .hero { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
    .hero h1 { font-size: clamp(3rem, 10vw, 6rem); font-weight: 800; letter-spacing: -0.05em; background: linear-gradient(#1d1d1f, #86868b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .hero-sub { color: var(--text-gray); letter-spacing: 0.3em; text-transform: uppercase; font-size: 0.8rem; margin-top: 10px; }

    /* 社交链接列表 */
    .container { max-width: 500px; margin: 0 auto; padding-bottom: 250px; }
    .nav-item { display: flex; align-items: center; justify-content: space-between; padding: 22px 28px; background: var(--glass); backdrop-filter: blur(20px); border: 1px solid rgba(0,0,0,0.05); border-radius: 24px; text-decoration: none; color: var(--text-dark); font-weight: 600; margin-bottom: 16px; transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .nav-item:hover { transform: scale(1.02) translateY(-4px); border-color: var(--miku-green); color: var(--miku-green); box-shadow: 0 15px 30px rgba(0,0,0,0.05); }

    /* 播放器 */
    .player-card { position: fixed; left: 25px; bottom: 25px; width: 280px; padding: 12px; background: var(--glass); backdrop-filter: blur(25px); border-radius: 22px; border: 1px solid rgba(0,0,0,0.08); display: flex; align-items: center; gap: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); z-index: 1000; }
    .album-cover { width: 48px; height: 48px; border-radius: 12px; object-fit: cover; background: #eee; transition: 0.5s; }
    .is-playing .album-cover { animation: rotate 12s linear infinite; }
    .song-info { flex: 1; overflow: hidden; }
    .song-name { font-size: 14px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-artist { font-size: 11px; color: var(--text-gray); }
    .play-pause { width: 36px; height: 36px; background: var(--text-dark); color: white; border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }

    /* 联系面板 (邮箱) */
    .contact-panel { position: fixed; right: 25px; bottom: 25px; display: flex; flex-direction: column; align-items: flex-end; gap: 8px; opacity: 0; transform: translateY(20px); transition: 0.5s; pointer-events: none; }
    body.is-bottom .contact-panel { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .email-chip { background: white; padding: 10px 18px; border-radius: 50px; font-size: 11px; color: var(--text-gray); border: 1px solid #eee; text-decoration: none; transition: 0.3s; font-family: monospace; }
    .email-chip:hover { background: var(--miku-green); color: white; border-color: var(--miku-green); }

    @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  </style>
</head>
<body>

  <div class="bg-glow"></div>

  <section class="hero">
    <h1>{title}</h1>
    <p class="hero-sub">Weather Holy Salt · TQSY</p>
  </section>

  <div class="container">
    <div class="nav-list">
      <a href="https://github.com/TQSY114514" class="nav-item">GitHub</a>
      <a href="https://luogu.com.cn/user/1849345" class="nav-item">Luogu</a>
      <a href="https://space.bilibili.com/1180124107" class="nav-item">Bilibili</a>
      <a href="https://x.com/TianY43737" class="nav-item">X (Twitter)</a>
      <a href="https://www.instagram.com/tqsy114514/" class="nav-item">Instagram</a>
      <a href="https://www.facebook.com/profile.php?id=61577768467133" class="nav-item">Facebook</a>
    </div>
  </div>

  <div class="player-card" id="playerCard">
    <img src="https://img.moegirl.org.cn/common/thumb/b/b7/Miku_v3_visual.png/250px-Miku_v3_visual.png" class="album-cover">
    <div class="song-info">
      <div class="song-name" id="sn">橙交差点</div>
      <div class="song-artist">初音ミク</div>
    </div>
    <button class="play-pause" id="playBtn">▶</button>
    <audio id="mainAudio" loop preload="auto">
      <source src="/miku.mp3" type="audio/mpeg">
    </audio>
  </div>

  <div class="contact-panel">
    <a href="mailto:tqishengyan@gmail.com" class="email-chip">tqishengyan@gmail.com</a>
    <a href="mailto:3635316905@qq.com" class="email-chip">3635316905@qq.com</a>
    <a href="mailto:tianqishengyan_zhj@163.com" class="email-chip">tianqishengyan_zhj@163.com</a>
    <a href="mailto:tianqishengyan_zhj@outlook.com" class="email-chip">tianqishengyan_zhj@outlook.com</a>
  </div>

  <script is:inline>
    const audio = document.getElementById('mainAudio');
    const playBtn = document.getElementById('playBtn');
    const playerCard = document.getElementById('playerCard');
    const sn = document.getElementById('sn');

    playBtn.onclick = () => {
      if (audio.paused) {
        audio.play().then(() => {
          playBtn.innerText = "⏸";
          playerCard.classList.add('is-playing');
          sn.innerText = "橙交差点";
        }).catch(err => {
          console.error(err);
          // 如果还是马叫或者 404，我们最后的 Debug
          sn.innerText = "文件解析失败(404)";
        });
      } else {
        audio.pause();
        playBtn.innerText = "▶";
        playerCard.classList.remove('is-playing');
      }
    };

    window.onscroll = () => {
      const isBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 150;
      document.body.classList.toggle('is-bottom', isBottom);
    };
  </script>
</body>
</html>
